# ============================================================================
#  AgentLedger — copy to .env  ·  fill the REAL section to go live
#  Everything is already wired. Mock works with zero config; the moment these
#  keys are set the app uses real Privy + real x402 + real Hermes. No code
#  changes. Never commit real secrets.
# ============================================================================

ENVIRONMENT=local
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./agentledger.db
# Production: postgresql+asyncpg://agent:agent@db:5432/agentledger

FRONTEND_ORIGIN=http://localhost:5173
RUN_MODE=inproc

# ---------------------------------------------------------------------------
#  1) AUTH — Privy wallet connect
#  Get these (free, ~2 min): https://dashboard.privy.io  → create app →
#  Settings. AUTH_MODE=dev runs a local sandbox identity with no Privy.
# ---------------------------------------------------------------------------
AUTH_MODE=dev                       # set to: privy
PRIVY_APP_ID=                       # e.g. clt1abcd... (also shown to frontend)
PRIVY_VERIFICATION_KEY=             # PEM public key from Privy dashboard
# Paste the PEM as one line with literal \n, or use a multi-line .env value:
# PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ---------------------------------------------------------------------------
#  2) PAYMENTS — real x402 on Base
#  PAYMENT_PROVIDER=x402 uses the real Coinbase x402 SDK + facilitator.
#  Start on Base SEPOLIA testnet (free test USDC, zero real money):
#    network  eip155:84532   ·   faucet https://faucet.circle.com (Base Sepolia USDC)
#  Mainnet when ready: eip155:8453 + a funded key + low caps.
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=mock               # set to: x402
X402_NETWORK=eip155:84532           # Base Sepolia testnet (8453 = mainnet)
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_EVM_PRIVATE_KEY=               # server-custodied signer (0x...). NEVER commit.
X402_ASSET_ADDRESS=                 # USDC contract for the chosen network
MOCK_API_PRICE_USDC=0.01            # price per paid call (USDC); change anytime

# ---------------------------------------------------------------------------
#  3) AGENT — real Hermes
#  Needs the `hermes` CLI on PATH + a model key. Set an agent's
#  config_json.runner = "hermes" (Agents tab) to use it instead of scripted.
# ---------------------------------------------------------------------------
HERMES_API_KEY=                     # model key for Hermes reasoning
