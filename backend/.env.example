# Copy to backend/.env (local) or set as host env vars (Railway). No real
# secrets in this file — it documents what the app needs.

ENVIRONMENT=local
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:///./agentledger.db
FRONTEND_ORIGIN=http://localhost:5173
RUN_MODE=inproc

# --- Auth: Privy wallet connect ---
AUTH_MODE=privy
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# --- Agent reasoning: Nous Hermes via OpenRouter ---
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-70b

# --- Payments: x402 on Solana ---
PAYMENT_PROVIDER=x402
X402_NETWORK=solana                 # 'solana' (mainnet) or 'solana-devnet'
X402_FACILITATOR_URL=https://facilitator.payai.network
X402_ASSET_ADDRESS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v   # mainnet USDC
X402_PAY_TO=your-solana-payout-address
X402_SVM_PRIVATE_KEY=               # base58 platform signer (funds spend)
X402_EVM_PRIVATE_KEY=
MOCK_API_PRICE_USDC=0.01
RUN_USAGE_FEE_USD=0.12
